# ─────────────────────────────────────────────
# Nexus AI — Environment Configuration
# Copy this to .env and fill in your values
# Run `npm run setup` for guided configuration
# ─────────────────────────────────────────────

# ═══ AI Provider (Required — choose one or both) ═══
AI_PROVIDER=openai
# Options: openai, gemini

# ═══ OpenAI ═══
OPENAI_API_KEY=sk-your-key-here
# Also used for Voice (Whisper STT + TTS) even if Gemini is the chat provider

# ═══ Google Gemini ═══
GEMINI_API_KEY=
# Get a key at https://aistudio.google.com/apikey

# ═══ AI Model ═══
AI_MODEL=gpt-4o-mini
# OpenAI options: gpt-4o, gpt-4o-mini, gpt-4-turbo
# Gemini options: gemini-2.5-pro, gemini-2.5-flash, gemini-2.0-flash, gemini-2.0-flash-lite

# ═══ Web Dashboard ═══
PORT=3000
# The web interface will be at http://localhost:3000

# ═══ Telegram ═══
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# ═══ Discord ═══
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=

# ═══ Slack ═══
SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ═══ WhatsApp ═══
WHATSAPP_ENABLED=false
# No token needed — uses QR code scan

# ═══ iMessage (macOS only) ═══
IMESSAGE_ENABLED=false
# No token needed — uses native AppleScript

# ═══ Voice ═══
VOICE_ENABLED=true
VOICE_MODEL=tts-1
VOICE_NAME=alloy
# Voice options: alloy, echo, fable, onyx, nova, shimmer
# Note: Voice always uses OpenAI (Whisper + TTS), even when Gemini is the chat provider

# ═══ System Prompt ═══
SYSTEM_PROMPT=You are Nexus, a helpful, friendly, and knowledgeable personal AI assistant. You are concise but thorough. You remember context from our conversation. You are running locally and all data stays private.
