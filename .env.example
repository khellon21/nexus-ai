# ─────────────────────────────────────────────
# Nexus AI — Environment Configuration
# Copy this to .env and fill in your values
# Run `npm run setup` for guided configuration
# ─────────────────────────────────────────────

# ═══ AI Provider (Required — choose one or both) ═══
AI_PROVIDER=openai
# Options: openai, gemini, nvidia

# ═══ OpenAI ═══
OPENAI_API_KEY=sk-your-key-here
# Also used for Voice (Whisper STT + TTS) even if Gemini/NVIDIA is the chat provider

# ═══ Google Gemini ═══
GEMINI_API_KEY=
# Get a key at https://aistudio.google.com/apikey

# ═══ NVIDIA NIM ═══
NVIDIA_API_KEY=
# Get a key at https://build.nvidia.com

# ═══ AI Model ═══
AI_MODEL=gpt-4o-mini
# OpenAI options: gpt-4o, gpt-4o-mini, gpt-4-turbo
# Gemini options: gemini-2.5-pro, gemini-2.5-flash, gemini-2.0-flash, gemini-2.0-flash-lite
# NVIDIA options: meta/llama-3.1-70b-instruct, nvidia/nemotron-4-340b-instruct, meta/llama-3.1-405b-instruct

# ═══ Web Dashboard ═══
PORT=3000
# The web interface will be at http://localhost:3000

# ═══ Telegram ═══
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# ═══ Owner (required for owner-only tools) ═══
# Your own Telegram user ID. This is the ONLY user allowed to invoke
# privileged tools like `take_screenshot` that can see/control the host
# machine. Any other Telegram user who messages this bot will be refused
# screen capture automatically.
#
# How to find your Telegram user ID:
#   1) Open Telegram and message @userinfobot
#   2) It replies with your numeric ID — paste it below
#
# If unset, owner-only tools are disabled entirely (fail-closed).
OWNER_TELEGRAM_USER_ID=

# ═══ Discord ═══
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=

# ═══ Slack ═══
SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ═══ WhatsApp ═══
WHATSAPP_ENABLED=false
# No token needed — uses QR code scan

# ═══ iMessage (macOS only) ═══
IMESSAGE_ENABLED=false
# No token needed — uses native AppleScript

# ═══ Voice ═══
VOICE_ENABLED=true
VOICE_MODEL=tts-1
VOICE_NAME=alloy
# Voice options: alloy, echo, fable, onyx, nova, shimmer
# Note: Voice always uses OpenAI (Whisper + TTS), even when Gemini is the chat provider

# ═══ System Prompt ═══
SYSTEM_PROMPT="You are Khellon's personal AI assistant. You have full access to a local Chrome browser via PinchTab tools (browser_navigate, browser_snapshot, browser_action, browser_extract_text). You must use these to autonomously check his college portal and read web news online. You must autonomously maintain awareness of his college environment and trigger send_urgent_notification for important updates."

# ═══ Cipher — Academic Automation Agent ═══
CIPHER_ENABLED=false
CIPHER_VAULT_KEY=                    # 32-byte hex key for credential encryption (run: node src/cipher-cli.js generate-key)
CIPHER_SCAN_INTERVAL=7200            # Seconds between portal scans (default: 2 hours)
CIPHER_TELEGRAM_CHAT_ID=             # Your personal Telegram chat ID for deadline alerts
CIPHER_ALERT_THRESHOLDS=48,24,6,1    # Hours before due date to send alerts
CIPHER_MACOS_NOTIFICATIONS=true      # Enable macOS Notification Center alerts
CIPHER_SUMMARY_HOUR=8                # Hour (0-23) to send daily assignment summary
# Optional: Twilio SMS
CIPHER_TWILIO_SID=
CIPHER_TWILIO_AUTH=
CIPHER_TWILIO_FROM=
CIPHER_TWILIO_TO=
