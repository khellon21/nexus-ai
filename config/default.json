{
  "app": {
    "name": "Nexus AI",
    "version": "1.0.0",
    "port": 3000
  },
  "ai": {
    "model": "gpt-4o-mini",
    "maxTokens": 4096,
    "temperature": 0.7,
    "contextWindow": 20,
    "streamResponses": true
  },
  "voice": {
    "enabled": true,
    "sttModel": "whisper-1",
    "ttsModel": "tts-1",
    "ttsVoice": "alloy",
    "maxAudioDuration": 120
  },
  "database": {
    "path": "./data/nexus.db"
  },
  "platforms": {
    "telegram": { "enabled": false, "typingIndicator": true },
    "discord": { "enabled": false, "respondToDMs": true, "respondToMentions": true },
    "slack": { "enabled": false, "respondToDMs": true, "respondToMentions": true },
    "whatsapp": { "enabled": false, "respondToGroups": false },
    "imessage": { "enabled": false, "pollIntervalMs": 3000 }
  },
  "logging": {
    "level": "info",
    "timestamps": true
  }
}
